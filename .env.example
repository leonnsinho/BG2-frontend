# Configurações do ambiente de desenvolvimento

# Supabase - SUBSTITUA PELOS VALORES REAIS
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Resend Email Service
# A chave da API do Resend é configurada APENAS no painel do Netlify (Environment Variables)
# como RESEND_API_KEY (sem prefixo VITE_). NÃO deve ser colocada aqui.
# Veja: Netlify Dashboard → Site settings → Environment variables → RESEND_API_KEY

# Configurações da aplicação
VITE_APP_NAME=BG2 Partimap
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# URLs
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173/api

# Stripe (chave pública — prefixo VITE_ necessário para uso no frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe (chaves privadas — configurar APENAS no painel do Netlify, nunca aqui)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase Service Role (configurar APENAS no painel do Netlify, nunca aqui)
# SUPABASE_URL=https://ecmgbinyotuxhiniadom.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...
